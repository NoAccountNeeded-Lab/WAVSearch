NODE_ENV=development

DATABASE_URL=postgresql://wav:wav@localhost:5432/wav_search
# Dev Container: DATABASE_URL is set automatically via remoteEnv — the value above is for local dev only.

# AI provider — set ANTHROPIC_API_KEY to use the self-healing scraper engine
# Omit or leave blank to disable AI-assisted remapping.
ANTHROPIC_API_KEY=
AI_PROVIDER=anthropic

# Ollama (alternative to Anthropic)
# Local dev:      http://localhost:11434
# Dev Container:  http://host.docker.internal:11434  (Docker Desktop only; Linux needs extra network config)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Scraper behavior
SCRAPER_CONCURRENCY=2
SCRAPER_REQUEST_DELAY_MS=2000
SCRAPER_HEADLESS=true
