NODE_ENV=development

DATABASE_URL=postgresql://wav:wav@localhost:5432/wav_search
# Dev Container: DATABASE_URL is set automatically via remoteEnv — the value above is for local dev only.

# Ollama — set OLLAMA_BASE_URL if running outside localhost (e.g. in Docker)
# Omit to disable AI-assisted selector remapping.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Scraper behavior
SCRAPER_CONCURRENCY=2
SCRAPER_REQUEST_DELAY_MS=2000
SCRAPER_HEADLESS=true
