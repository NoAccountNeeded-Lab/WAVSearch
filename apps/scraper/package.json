{
  "name": "@wivwav/scraper",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run src/**/*.integration.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@playwright/test": "^1.60.0",
    "@wivwav/agents": "workspace:*",
    "@wivwav/db": "workspace:*",
    "@wivwav/queue": "workspace:*",
    "@wivwav/search": "workspace:*",
    "@wivwav/types": "workspace:*",
    "dotenv": "^17.4.2",
    "meilisearch": "^0.58.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@wivwav/config": "workspace:*",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
