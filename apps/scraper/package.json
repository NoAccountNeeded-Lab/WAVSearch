{
  "name": "@wivwav/scraper",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run src/**/*.integration.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@playwright/test": "^1.60.0",
    "@wivwav/agents": "workspace:*",
    "@wivwav/db": "workspace:*",
    "@wivwav/queue": "workspace:*",
    "@wivwav/search": "workspace:*",
    "@wivwav/types": "workspace:*",
    "meilisearch": "^0.47.0",
    "dotenv": "^17.4.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@wivwav/config": "workspace:*",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.2"
  }
}
