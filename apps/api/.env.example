NODE_ENV=development
PORT=3001
HOST=0.0.0.0

DATABASE_URL=postgresql://wav:wav@localhost:5432/wivwav

MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=wav_master_key

VALKEY_URL=redis://localhost:6379
QUEUE_REDIS_URL=redis://localhost:6379

CORS_ORIGIN=http://localhost:3000

# Secret config DB encryption (AES-256-GCM, 64-char hex / 32 bytes)
# Generate: openssl rand -hex 32
# CONFIG_ENCRYPTION_SECRET=

# Shared secret for server-to-server /admin/config/:key/decrypt calls.
# Set the same value in apps/web and packages/agents environments.
# Generate: openssl rand -hex 32
# INTERNAL_API_SECRET=

# Loki log aggregation backend (used by GET /admin/logs).
# Default works for local `make dev`. Docker Compose overrides this to http://loki:3100.
# LOKI_URL=http://localhost:3100

# Sentry error monitoring
# Create a project at https://sentry.io and paste the DSN here.
# Omit to disable Sentry entirely (fine for local dev).
# SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/789
