    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bull-board/api": "^7.1.5",
    "@bull-board/fastify": "^7.1.5",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.1",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.1",
    "@wav-search/db": "workspace:*",
    "@wav-search/queue": "workspace:*",
    "@wav-search/types": "workspace:*",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.1",
    "ioredis": "^5.11.0",
    "meilisearch": "^0.47.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@wav-search/config": "workspace:*",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
