NEXT_PUBLIC_API_URL=http://localhost:3001

# Internal API URL for server-to-server calls (e.g. /admin/config/decrypt).
# Set to an internal hostname in production so decrypt calls never leave the private network.
# Defaults to NEXT_PUBLIC_API_URL when unset (fine for local dev).
# API_INTERNAL_URL=http://api:3003

# Must match INTERNAL_API_SECRET in apps/api — required in production.
# INTERNAL_API_SECRET=

# AI provider config (provider, model, API key) is managed via /ops/ai — no env vars needed
