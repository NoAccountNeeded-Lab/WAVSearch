NEXT_PUBLIC_API_URL=http://localhost:3001

# Internal API URL for server-to-server calls (e.g. /admin/config/decrypt).
# Set to an internal hostname in production so decrypt calls never leave the private network.
# Defaults to NEXT_PUBLIC_API_URL when unset (fine for local dev).
# API_INTERNAL_URL=http://api:3003

# Must match INTERNAL_API_SECRET in apps/api — required in production.
# INTERNAL_API_SECRET=

# AI provider config (provider, model, API key) is managed via /ops/ai — no env vars needed

# Sentry error monitoring
# Create a project at https://sentry.io and paste the DSN here.
# NEXT_PUBLIC_SENTRY_DSN is visible in browser bundle; SENTRY_DSN is server-only.
# Omit both to disable Sentry entirely (fine for local dev).
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/789
# SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/789
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=wivwav-web
# SENTRY_AUTH_TOKEN=  # Required for source map upload at build time; generate at sentry.io/settings/auth-tokens/
