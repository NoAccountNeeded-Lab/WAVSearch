generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceStatus {
  active
  paused
  error
  needs_remapping
}

enum ConversionType {
  rear_entry
  side_entry
  unknown
}

enum RampType {
  in_floor
  fold_out
  fold_in
  none
  unknown
}

enum ListingCondition {
  new
  used
  certified_pre_owned
}

enum ListingSellerType {
  dealer
  private
}

enum ListingStatus {
  active
  possibly_gone
  gone
}

enum SaleStatus {
  active
  pending
  sold
}

model Source {
  id              String       @id @default(cuid())
  name            String       @unique
  baseUrl         String
  status          SourceStatus @default(active)
  cronExpression  String       @default("0 */6 * * *")
  timezone        String       @default("America/New_York")
  mappings        Json         @default("[]")
  fingerprintHash String?
  page1Hash       String?
  lastScrapedAt   DateTime?
  lastCheckedAt   DateTime?
  listingCount    Int          @default(0)
  errorMessage    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  listings Listing[]

  @@map("sources")
}

model Listing {
  id         String @id @default(cuid())
  sourceId   String
  source     Source @relation(fields: [sourceId], references: [id])
  sourceUrl  String
  buyerUrl   String?
  externalId String?

  make         String
  model        String
  year         Int
  trim         String?
  vin          String?
  condition    ListingCondition
  sellerType   ListingSellerType

  priceCents Int?
  mileage    Int?
  color      String?
  fuelType   String?
  transmission String?

  // WAV-specific
  conversionType         ConversionType @default(unknown)
  conversionManufacturer String?
  floorLoweringInches    Float?
  rampType               RampType       @default(unknown)
  hasLift                Boolean        @default(false)
  handControls           Boolean        @default(false)
  transferSeat           Boolean        @default(false)
  wheelchairCapacity     Int?

  // Location
  zip   String?
  city  String?
  state String?
  lat   Float?
  lng   Float?

  // Normalized vehicle model reference (optional, populated during enrichment)
  vehicleModelId               String?
  vehicleModelMatchConfidence  String?
  vehicleModel                 VehicleModel? @relation(fields: [vehicleModelId], references: [id])

  // Dealer
  dealerName    String?
  dealerPhone   String?
  dealerWebsite String?

  images      String[]
  description String?

  // Deduplication
  isDuplicate Boolean @default(false)
  canonicalId String?
  canonical   Listing?  @relation("DuplicateOf", fields: [canonicalId], references: [id])
  duplicates  Listing[] @relation("DuplicateOf")

  status     ListingStatus @default(active)
  saleStatus SaleStatus    @default(active)
  goneAt     DateTime?
  soldAt     DateTime?

  listedAt        DateTime
  updatedAt       DateTime  @updatedAt
  scrapedAt       DateTime  @default(now())
  detailScrapedAt DateTime?

  priceHistory ListingPriceHistory[]

  @@unique([sourceId, externalId])
  @@index([sourceId])
  @@index([sourceUrl])
  @@index([vin])
  @@index([isDuplicate])
  @@index([state])
  @@index([make, model])
  @@index([year])
  @@index([priceCents])
  @@index([mileage])
  @@index([listedAt])
  @@index([status])
  @@index([vehicleModelId])
  @@map("listings")
}

model ListingPriceHistory {
  id         String   @id @default(cuid())
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id])
  priceCents Int
  recordedAt DateTime @default(now())

  @@index([listingId, recordedAt])
  @@map("listing_price_history")
}

model RawPage {
  id          String    @id @default(cuid())
  url         String    @unique
  sourceId    String
  html        String
  scrapedAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([sourceId, processedAt])
  @@index([processedAt, scrapedAt])
  @@map("raw_pages")
}

model ScraperRun {
  id         String   @id @default(cuid())
  sourceId   String
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  success    Boolean?
  listingsFound    Int?
  listingsNew      Int?
  listingsUpdated  Int?
  errorMessage     String?

  @@index([sourceId])
  @@map("scraper_runs")
}

// ── Research platform ──────────────────────────────────────────────────────

model VehicleModel {
  id       String  @id @default(cuid())
  make     String
  model    String
  year     Int
  trim     String?
  bodyType String?

  listings      Listing[]
  recalls       Recall[]
  complaints    Complaint[]
  safetyRatings SafetyRating[]

  @@unique([make, model, year, trim])
  @@index([make, model])
  @@index([year])
  @@map("vehicle_models")
}

model Recall {
  id              String       @id @default(cuid())
  nhtsaCampaignId String
  vehicleModelId  String
  vehicleModel    VehicleModel @relation(fields: [vehicleModelId], references: [id])
  component       String
  summary         String
  remedy          String?
  reportedAt      DateTime
  createdAt       DateTime     @default(now())

  @@unique([nhtsaCampaignId, vehicleModelId])
  @@index([vehicleModelId])
  @@map("recalls")
}

model Complaint {
  id             String       @id @default(cuid())
  nhtsaId        String       @unique
  vehicleModelId String
  vehicleModel   VehicleModel @relation(fields: [vehicleModelId], references: [id])
  component      String
  summary        String
  mileage        Int?
  crashInvolved  Boolean      @default(false)
  reportedAt     DateTime
  createdAt      DateTime     @default(now())

  @@index([vehicleModelId])
  @@map("complaints")
}

model SafetyRating {
  id              String       @id @default(cuid())
  vehicleModelId  String
  vehicleModel    VehicleModel @relation(fields: [vehicleModelId], references: [id])
  nhtsaVehicleId  Int          @unique
  description     String?
  overallRating   Int?
  frontCrashRating Int?
  sideCrashRating  Int?
  rolloverRating   Int?
  rolloverRatingText String?
  refreshedAt     DateTime     @default(now())

  @@index([vehicleModelId])
  @@map("safety_ratings")
}

model ConversionBrand {
  id             String   @id @default(cuid())
  name           String   @unique
  slug           String   @unique
  website        String?
  nmedaCertified Boolean  @default(false)
  founded        Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products ConversionProduct[]

  @@map("conversion_brands")
}

model ConversionProduct {
  id                  String          @id @default(cuid())
  brandId             String
  brand               ConversionBrand @relation(fields: [brandId], references: [id])
  name                String
  conversionType      ConversionType
  rampType            RampType
  floorLoweringInches Float?
  msrpCents           Int?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([brandId])
  @@map("conversion_products")
}

model VehicleStats {
  id                String   @id @default(cuid())
  make              String
  model             String
  year              Int?
  avgLifespanMiles  Int?
  reliabilityScore  Float?
  reliabilitySource String?
  jdPowerScore      Float?
  refreshedAt       DateTime?
  createdAt         DateTime @default(now())

  @@unique([make, model, year])
  @@index([make, model])
  @@map("vehicle_stats")
}

model NmeaDealer {
  id           String   @id @default(cuid())
  name         String
  address      String?
  state        String?
  zip          String?
  phone        String?
  website      String?
  qapCertified Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([state])
  @@map("nmea_dealers")
}
