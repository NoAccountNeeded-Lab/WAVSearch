# Which AI provider to use (default: anthropic)
# Options: anthropic | ollama | openai | copilot
AGENTS_PROVIDER=anthropic

# Model override — each provider has a default if this is unset
# anthropic default: claude-sonnet-4-6
# ollama default:    llama3.2
# openai default:    gpt-4o
# copilot default:   gpt-4o
AGENTS_MODEL=

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Ollama
AGENTS_OLLAMA_BASE_URL=http://localhost:11434

# GitHub Copilot / GitHub Models
# Token: a GitHub PAT with model access (or GITHUB_TOKEN from CI)
AGENTS_COPILOT_TOKEN=
# Base URL defaults to GitHub Models API (https://models.inference.ai.azure.com)
AGENTS_COPILOT_BASE_URL=
