{
  "name": "wivwav",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean",
    "db:generate": "pnpm --filter @wivwav/db generate",
    "db:migrate": "pnpm --filter @wivwav/db migrate",
    "db:migrate:create": "pnpm --filter @wivwav/db migrate:create",
    "db:push": "pnpm --filter @wivwav/db db:push",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "agents": "pnpm --filter @wivwav/agents run cli --",
    "job:detail-crawl": "pnpm --filter @wivwav/scraper job:detail-crawl",
    "job:detail-extract": "pnpm --filter @wivwav/scraper job:detail-extract",
    "job:geocode": "pnpm --filter @wivwav/scraper job:geocode"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "turbo": "^2.9.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
