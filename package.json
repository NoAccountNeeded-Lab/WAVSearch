{
  "name": "wav-search",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean",
    "db:generate": "pnpm --filter @wav-search/db generate",
    "db:migrate": "pnpm --filter @wav-search/db migrate",
    "db:migrate:create": "pnpm --filter @wav-search/db migrate:create",
    "db:push": "pnpm --filter @wav-search/db db:push",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "agents": "pnpm --filter @wav-search/agents run cli --",
    "job:detail-crawl": "pnpm --filter @wav-search/scraper job:detail-crawl",
    "job:detail-extract": "pnpm --filter @wav-search/scraper job:detail-extract",
    "job:geocode": "pnpm --filter @wav-search/scraper job:geocode"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "prettier": "^3.4.2",
    "turbo": "^2.9.16",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.60.0"
  }
}
